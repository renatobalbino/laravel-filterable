{
    "name": "renatobalbino/laravel-filterable",
    "description": "Filter package to Laravel/Lumen",
    "type": "package",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "laravel/framework": "^v12.37.0"
    },
    "autoload": {
        "psr-4": {
            "RbdevSys\\Filterable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RbdevSys\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^v4.1.3",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
